<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.asset.mapper.ChangeAttachmentMapper">

    <resultMap type="com.ruoyi.asset.domain.ChangeAttachment" id="ChangeAttachmentResult">
        <id property="id" column="id"/>
        <result property="masterId" column="master_id"/>
        <result property="attachmentName" column="attachment_name"/>
        <result property="attachmentType" column="attachment_type"/>
        <result property="filePath" column="file_path"/>
        <result property="uploadBy" column="upload_by"/>
        <result property="uploadTime" column="upload_time"/>
        <result property="delFlag" column="del_flag"/>
    </resultMap>

    <sql id="selectChangeAttachmentVo">
        select id,
               master_id,
               attachment_name,
               attachment_type,
               file_path,
               upload_by,
               upload_time,
               del_flag
        from asset_change_attachment
    </sql>

    <select id="selectChangeAttachmentList" parameterType="com.ruoyi.asset.domain.ChangeAttachment" resultMap="ChangeAttachmentResult">
        <include refid="selectChangeAttachmentVo"/>
        <where>
            del_flag = '0'
            <if test="masterId != null">
                AND master_id = #{masterId}
            </if>
            <if test="attachmentType != null and attachmentType != ''">
                AND attachment_type = #{attachmentType}
            </if>
        </where>
        order by upload_time asc
    </select>

    <delete id="deleteByMasterId" parameterType="Long">
        delete
        from asset_change_attachment
        where master_id = #{masterId}
    </delete>

</mapper>
