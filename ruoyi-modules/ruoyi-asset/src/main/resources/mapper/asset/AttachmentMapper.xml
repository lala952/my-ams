<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.asset.mapper.AttachmentMapper">

    <resultMap type="com.ruoyi.asset.domain.Attachment" id="AttachmentResult">
        <result property="id" column="id"/>
        <result property="assetId" column="asset_id"/>
        <result property="attachmentName" column="attachment_name"/>
        <result property="attachmentType" column="attachment_type"/>
        <result property="filePath" column="file_path"/>
        <result property="fileSize" column="file_size"/>
        <result property="isMain" column="is_main"/>
        <result property="sortOrder" column="sort_order"/>
        <result property="uploadBy" column="upload_by"/>
        <result property="uploadTime" column="upload_time"/>
        <result property="delFlag" column="del_flag"/>
    </resultMap>

    <sql id="selectAttachmentVo">
        select id,
               asset_id,
               attachment_name,
               attachment_type,
               file_path,
               file_size,
               is_main,
               sort_order,
               upload_by,
               upload_time,
               del_flag
        from asset_attachment
    </sql>

    <!-- 查询接口（复杂条件） -->
    <select id="selectAttachmentList" parameterType="com.ruoyi.asset.domain.Attachment" resultMap="AttachmentResult">
        <include refid="selectAttachmentVo"/>
        <where>
            <if test="assetId != null">and asset_id = #{assetId}</if>
            <if test="attachmentName != null and attachmentName != ''">
                and attachment_name like concat('%', #{attachmentName}, '%')
            </if>
            <if test="attachmentType != null and attachmentType != ''">
                and attachment_type = #{attachmentType}
            </if>
            <if test="isMain != null">and is_main = #{isMain}</if>
            <if test="uploadBy != null and uploadBy != ''">and upload_by = #{uploadBy}</if>
            and del_flag = '0'
        </where>
        order by sort_order asc, id desc
    </select>

    <!-- 批量查询 -->
    <select id="selectAttachmentByIds" resultMap="AttachmentResult">
        <include refid="selectAttachmentVo"/>
        where id in
        <foreach collection="ids" item="id" open="(" separator="," close=")">
            #{id}
        </foreach>
        and del_flag = '0'
    </select>

</mapper>