<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.asset.mapper.ChangeMapper">

    <resultMap type="Change" id="ChangeResult">
        <result property="id" column="id"/>
        <result property="changeCode" column="change_code"/>
        <result property="changeType" column="change_type"/>
        <result property="changeReason" column="change_reason"/>
        <result property="applyDate" column="apply_date"/>
        <result property="applicantId" column="applicant_id"/>
        <result property="procInstId" column="proc_inst_id"/>
        <result property="businessStatus" column="business_status"/>
        <result property="createBy" column="create_by"/>
        <result property="createTime" column="create_time"/>
        <result property="updateBy" column="update_by"/>
        <result property="updateTime" column="update_time"/>
        <result property="delFlag" column="del_flag"/>
    </resultMap>

    <resultMap type="com.ruoyi.asset.domain.vo.ChangeVO" id="ChangeVOResult" extends="ChangeResult">
        <result property="applicantName" column="applicant_name"/>
        <result property="applicantDeptName" column="applicant_dept_name"/>
        <collection property="attachments" ofType="ChangeAttachment"
                    select="com.ruoyi.asset.mapper.ChangeAttachmentMapper.selectChangeAttachmentList"
                    column="{masterId=id}"/>
    </resultMap>

    <resultMap type="ChangeDetail" id="ChangeDetailResult">
        <result property="id" column="id"/>
        <result property="masterId" column="master_id"/>
        <result property="assetId" column="asset_id"/>
    </resultMap>

    <sql id="selectChangeVo">
        select distinct c.id,
                        c.change_code,
                        c.change_type,
                        c.change_reason,
                        c.apply_date,
                        c.applicant_id,
                        c.proc_inst_id,
                        c.business_status,
                        c.create_time,
                        c.update_time,
                        c.remark,
                        c.create_by,
                        c.update_by,
                        c.del_flag,
                        u.nick_name as applicant_name,
                        d.dept_name  as applicant_dept_name
        from asset_change c
                 left join sys_user u on c.applicant_id = u.user_id
                 left join sys_dept d on u.dept_id = d.dept_id
        where c.del_flag = '0'
    </sql>

    <select id="selectChangeList" parameterType="Change" resultMap="ChangeVOResult">
        <include refid="selectChangeVo"/>
        <if test="changeCode != null and changeCode != ''">
            AND c.change_code = #{changeCode}
        </if>
        <if test="changeType != null and changeType != ''">
            AND c.change_type = #{changeType}
        </if>
        <if test="applicantId != null">
            AND c.applicant_id = #{applicantId}
        </if>
        <if test="businessStatus != null and businessStatus != ''">
            AND c.business_status = #{businessStatus}
        </if>
        <if test="params.beginTime != null and params.beginTime != ''">
            AND date_format(c.create_time,'%Y%m%d') &gt;= date_format(#{params.beginTime},'%Y%m%d')
        </if>
        <if test="params.endTime != null and params.endTime != ''">
            AND date_format(c.create_time,'%Y%m%d') &lt;= date_format(#{params.endTime},'%Y%m%d')
        </if>
        order by c.id desc
    </select>

    <!-- 统计各业务状态数量 - 从业务表直接统计 -->
    <select id="countByBusinessStatus" resultType="java.util.Map">
        SELECT SUM(CASE WHEN business_status = 'draft' THEN 1 ELSE 0 END)     AS draft,
               SUM(CASE WHEN business_status = 'pending' THEN 1 ELSE 0 END)   AS pending,
               SUM(CASE WHEN business_status = 'completed' THEN 1 ELSE 0 END) AS completed,
               SUM(CASE WHEN business_status = 'rejected' THEN 1 ELSE 0 END)  AS rejected
        FROM asset_change
        WHERE del_flag = '0'
    </select>

    <select id="selectChangeById" parameterType="Long" resultMap="ChangeVOResult">
        <include refid="selectChangeVo"/>
        and c.id = #{id}
    </select>

    <select id="selectDetailListByMasterId" parameterType="Long" resultMap="ChangeDetailResult">
        select d.id, d.master_id, d.asset_id
        from asset_change_detail d
        where d.master_id = #{masterId}
        order by d.id
    </select>

    <update id="deleteChangeByIds" parameterType="Long">
        update asset_change set del_flag = '2' where id in
        <foreach collection="array" item="id" open="(" separator="," close=")">
            #{id}
        </foreach>
    </update>

    <insert id="batchInsertDetail" parameterType="list">
        insert into asset_change_detail (master_id, asset_id) values
        <foreach collection="list" item="item" separator=",">
            (#{item.masterId}, #{item.assetId})
        </foreach>
    </insert>

    <delete id="deleteDetailByMasterId" parameterType="Long">
        delete
        from asset_change_detail
        where master_id = #{masterId}
    </delete>

    <select id="selectAssetsByChangeId" parameterType="Long" resultType="com.ruoyi.asset.domain.Assets">
        select a.*
        from asset_assets a
                 inner join asset_change_detail d on a.id = d.asset_id
        where d.master_id = #{changeId}
        order by d.id
    </select>

</mapper>