<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.asset.mapper.HistoryMapper">

    <resultMap type="com.ruoyi.asset.domain.History" id="HistoryResult">
        <result property="id" column="id"/>
        <result property="assetId" column="asset_id"/>
        <result property="eventType" column="event_type"/>
        <result property="eventName" column="event_name"/>
        <result property="eventDetail" column="event_detail"/>
        <result property="beforeData" column="before_data"/>
        <result property="afterData" column="after_data"/>
        <result property="operatorId" column="operator_id"/>
        <result property="operatorName" column="operator_name"/>
        <result property="operateTime" column="operate_time"/>
        <result property="ipAddress" column="ip_address"/>
        <result property="delFlag" column="del_flag"/>
    </resultMap>

    <sql id="selectHistoryVo">
        select id,
               asset_id,
               event_type,
               event_name,
               event_detail,
               before_data,
               after_data,
               operator_id,
               operator_name,
               operate_time,
               ip_address,
               del_flag
        from asset_history
    </sql>

    <select id="selectHistoryList" parameterType="com.ruoyi.asset.domain.History" resultMap="HistoryResult">
        <include refid="selectHistoryVo"/>
        <where>
            <if test="assetId != null ">and asset_id = #{assetId}</if>
            <if test="eventType != null  and eventType != ''">and event_type = #{eventType}</if>
            <if test="eventName != null  and eventName != ''">and event_name like concat('%', #{eventName}, '%')</if>
            <if test="eventDetail != null  and eventDetail != ''">and event_detail = #{eventDetail}</if>
            <if test="beforeData != null  and beforeData != ''">and before_data = #{beforeData}</if>
            <if test="afterData != null  and afterData != ''">and after_data = #{afterData}</if>
            <if test="operatorId != null ">and operator_id = #{operatorId}</if>
            <if test="operatorName != null  and operatorName != ''">and operator_name like concat('%', #{operatorName},
                '%')
            </if>
            <if test="operateTime != null ">and operate_time = #{operateTime}</if>
            <if test="ipAddress != null  and ipAddress != ''">and ip_address = #{ipAddress}</if>
            AND del_flag = '0'
        </where>
        order by operate_time desc
    </select>

    <!-- 插入资产履历（Map参数）- 供资产变动使用 -->
    <insert id="insertHistory" parameterType="java.util.Map">
        INSERT INTO asset_history (asset_id, event_type, event_name, event_detail,
                                   operator_id, operator_name, operate_time)
        VALUES (#{assetId}, #{eventType}, #{eventName}, #{eventDetail},
                #{operatorId}, #{operatorName}, #{operateTime})
    </insert>
</mapper>